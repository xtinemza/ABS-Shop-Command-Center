{
  "_description": "Recall Notifications — NHTSA lookup, urgency rules, notification templates",

  "nhtsa_api": {
    "complaints_url": "https://api.nhtsa.gov/complaints/complaintsByVehicle",
    "recalls_url": "https://api.nhtsa.gov/recalls/recallsByVehicle",
    "recalls_by_vin_url": "https://api.nhtsa.gov/recalls/recallsByVin/{vin}",
    "note": "Free public API — no key required. VIN lookup is the most accurate method."
  },

  "urgency_levels": {
    "safety_critical": {
      "label": "Safety Recall — Remedy Required",
      "trigger_keywords": ["crash", "fire", "injury", "death", "rollover", "fuel leak", "brake failure", "steering loss", "airbag"],
      "customer_action": "Do not drive until remedy is completed — contact dealer immediately.",
      "shop_action": "Inform customer in person or by phone first. Follow with written notification.",
      "notification_channels": ["phone_script", "sms", "email"]
    },
    "high": {
      "label": "Important Safety Recall",
      "trigger_keywords": ["stall", "loss of power", "unintended acceleration", "electrical fire", "seatbelt"],
      "customer_action": "Schedule remedy with dealer as soon as possible.",
      "shop_action": "Notify same day. Include remedy steps.",
      "notification_channels": ["sms", "email"]
    },
    "medium": {
      "label": "Recall — Remedy Recommended",
      "trigger_keywords": ["corrosion", "software", "sensor", "module", "misfeed", "label"],
      "customer_action": "Schedule with dealer within 30 days.",
      "shop_action": "Include in service summary. Add to declined services follow-up if not acted on.",
      "notification_channels": ["sms", "email"]
    }
  },

  "notification_templates": {
    "sms": {
      "max_chars": 160,
      "template": "Hi [FirstName], your [Year] [Make] [Model] has an open safety recall ([CampaignID]): [Summary]. Contact [DealerName] at [DealerPhone] — remedy is FREE. Questions? Call us at [ShopPhone]."
    },
    "email": {
      "subject": "Important: Open Recall on Your [Year] [Make] [Model]",
      "sections": ["recall_summary", "consequence_plain_language", "remedy_steps", "dealer_contact", "shop_note"]
    },
    "shop_note": {
      "template": "RECALL FLAGGED: [CampaignID] — [Summary]. Customer notified [Date]. Remedy must be performed by authorized dealer.",
      "add_to": "repair order and service history"
    }
  },

  "vin_format": {
    "length": 17,
    "valid_chars": "A-H J-N P R-Z 0-9",
    "invalid_chars": "I O Q",
    "note": "Always validate VIN length and exclude I, O, Q before NHTSA lookup."
  },

  "compliance_note": "The shop is not responsible for performing recall repairs — that is the dealer's obligation. The shop's role is notification and documentation. Always advise the customer to contact an authorized dealer.",

  "documentation_rules": [
    "Record recall notification in the vehicle's service history.",
    "Note the NHTSA campaign ID, date notified, and channel used.",
    "If customer declines to act, document that they were informed.",
    "Re-notify at next service visit if recall remains open."
  ],

  "notorious_historical_recalls": {
